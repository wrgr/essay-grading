# Copy to .env and fill in what you use. Everything is optional:
# with no LLM keys the platform runs in keyword-fallback scoring mode.

# ── LLM provider keys (server-side only; never exposed to the browser) ────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GITHUB_MODELS_TOKEN=
# Ollama needs no key — it is auto-detected at http://localhost:11434

# Default provider shown in pickers (OpenAI | Claude | Gemini | Groq | Mistral |
# GitHub Models | Ollama)
DEFAULT_PROVIDER=Claude

# ── Storage ────────────────────────────────────────────────────────────────────
# Directory for the SQLite database and generated artifacts (default: backend/data)
#ASSESSMENT_DATA_DIR=
# Full override for the database file path
#ASSESSMENT_DB_PATH=
